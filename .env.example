NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:[password]@host:6543/postgres
CORS_ORIGINS=http://localhost:5173

# Supabase (backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # clave secreta para Admin API
ONLY_ALLOWED_EMAIL=desarrollo@urbani.cl

# AWS RDS replica (Moby) — solo lectura
MOBY_REPLICA_DB_HOST=mobysuite-gc2-urbani-replica.c1zztf8orfzy.us-east-1.rds.amazonaws.com
MOBY_REPLICA_DB_PORT=3306
MOBY_REPLICA_DB_NAME=mobysuite_gc2_urbani
MOBY_REPLICA_DB_USER=urbani_gc2_guest_view
MOBY_REPLICA_DB_PASSWORD=your-moby-password

# Frontend (frontend/.env.local)
VITE_API_URL=http://localhost:3100
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
