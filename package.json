{
  "name": "urbani-smart-scheduling",
  "version": "1.0.0",
  "description": "Urbani Smart Scheduling API",
  "main": "src/server.js",
  "scripts": {
    "db:init": "node src/db/init.js",
    "db:seed": "node src/db/seed.js",
    "start": "node src/server.js",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:start\" \"npm:frontend:dev\"",
    "frontend:install": "npm --prefix frontend install",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "license": "MIT"
}
